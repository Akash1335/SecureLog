# SecureLog Environment Configuration
# Instructions:
# 1. Rename this file to .env (cmd: ren .env.template .env)
# 2. Fill in your Gmail credentials below.
# 3. For MAIL_PASSWORD, use an "App Password" from your Google Account settings.

MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
JWT_SECRET_KEY=super-secret-random-key-123
